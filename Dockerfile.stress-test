FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

COPY scripts/stress-test-requirements.txt /tmp/stress-test-requirements.txt
RUN pip install --no-cache-dir -r /tmp/stress-test-requirements.txt

ENTRYPOINT ["python", "/app/stress-test.py"]