{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chain-registry.local/schemas/evidence-bundle.schema.json",
  "title": "Chain Registry Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_bundle_id",
    "package",
    "scanner_profile_digest",
    "analysis_bundles",
    "deterministic_risk",
    "findings",
    "artifacts",
    "evidence_digest",
    "signed_by"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "evidence_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ecosystem",
        "name",
        "version",
        "canonical",
        "content_hash"
      ],
      "properties": {
        "ecosystem": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "canonical": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "scanner_profile_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "analysis_bundles": {
      "$ref": "scanner-profile.schema.json#/$defs/analysis_bundles"
    },
    "deterministic_risk": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "score",
        "band",
        "disposition"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "band": {
          "type": "string",
          "minLength": 1
        },
        "disposition": {
          "enum": [
            "approve",
            "reject",
            "review"
          ]
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[0-9a-f]{64}$"
      },
      "minProperties": 1
    },
    "evidence_digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "signed_by": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "scanner-profile.schema.json#/$defs/signature"
      }
    }
  }
}
