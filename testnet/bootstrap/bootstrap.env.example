# Chain Registry Bootstrap Node Environment
# Copy to bootstrap.env and fill in real values. NEVER commit bootstrap.env.

# ── Node Identity ─────────────────────────────────────────────────────────────
NODE_ID=bootstrap-1
CREG_NODE_ID=bootstrap-1

# ── Chain Spec ────────────────────────────────────────────────────────────────
# URL to the signed chain spec (required)
CREG_CHAIN_SPEC_URL=https://testnet.creg.example/chain-spec.json

# Pinning: fail if spec doesn't match these values
CREG_CHAIN_ID=creg-testnet-1
CREG_GENESIS_HASH=0xd4f02667b3133de996f2ef9950ec4065d1f0ead101ca40e7f7455446872204b6

# Spec signing pubkey (Ed25519 hex, 64 chars)
CREG_SPEC_SIGNING_PUBKEY=0437e4adac481519cd6ae66907294c40cfcbf0bdeadd47806f6233be4bd5f82d

# ── L1 RPC ────────────────────────────────────────────────────────────────────
# Sepolia RPC endpoint (Infura, Alchemy, or self-hosted)
CREG_ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# ── P2P ───────────────────────────────────────────────────────────────────────
# The address this node listens on
CREG_P2P_LISTEN=/ip4/0.0.0.0/tcp/9000

# Bootstrap nodes typically have NO seeds (they are the roots)
# But you can point to other boots for redundancy
CREG_P2P_SEEDS=

# Announce address — what peers should dial to reach this node.
# Must be a public IP or DNS name. Examples:
#   /dns4/bootnode-1.creg-testnet.example/tcp/9000
#   /ip4/203.0.113.1/tcp/9000
CREG_P2P_ANNOUNCE=/dns4/YOUR_HOSTNAME/tcp/9000

# ── REST API ──────────────────────────────────────────────────────────────────
# Health endpoint for load balancers / monitoring
CREG_LISTEN=0.0.0.0:8080

# ── Disable non-bootstrap subsystems ──────────────────────────────────────────
# Bootstrap nodes don't validate or produce blocks
CREG_VALIDATOR=false

# ── Data directory ────────────────────────────────────────────────────────────
# Persistent storage for chain DB and P2P identity
CREG_DATA_DIR=/data

# ── Optional: Cloudflare Tunnel ───────────────────────────────────────────────
# Only needed if running behind NAT without port forwarding
# TUNNEL_TOKEN=your-cloudflare-tunnel-token
