# Chain Registry — 3-Node Sepolia Docker Fleet
#
# Quick start (recommended):
#   .\testnet\init-sepolia-3node-env.ps1
#   .\testnet\start-3node-test.ps1
#
# Manual copy:
#   Copy-Item testnet\sepolia-3node.env.example testnet\sepolia-3node.env
#
# start-3node-test.ps1 also merges testnet/.env.sepolia when sepolia-3node.env is missing.

# ── Sepolia RPC (required) ──
# Dedicated provider key recommended for validator_set_sync (avoid shared public endpoints).
# Options: Infura, Alchemy, QuickNode, or Option A self-hosted Geth (internal VPC only).
# Architecture: docs/GCP-RPC-ARCHITECTURE.md
# Option A runbook: docs/GCP-SEPOLIA-GETH-INTERNAL.md
#   .\testnet\gcp\get-sepolia-geth-rpc-url.ps1  -> http://10.128.0.X:8545
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
CREG_ETH_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# Option A (after provision-sepolia-geth-vm.ps1 + deploy-sepolia-geth.ps1):
# SEPOLIA_RPC_URL=http://10.128.0.X:8545
# CREG_ETH_RPC=http://10.128.0.X:8545
# IMPORTANT: set each RPC variable once. Duplicate keys break fleet contract validation.
# Validator fleet on GCP: use publicnode (internal geth may lack contract bytecode; Infura may fail from validator VM).
# CREG_ETH_RPC=https://ethereum-sepolia-rpc.publicnode.com
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ── Validator fleet mode (production — validators on creg-validator-vm) ──
# See docs/GCP-VALIDATOR-FLEET.md
# CREG_VALIDATOR_FLEET_MODE=true
# CREG_VALIDATOR_VM_INTERNAL_IP=10.128.0.X
# CREG_EDGE_INTERNAL_IP=10.128.0.Y
# CREG_IPFS_URL=http://10.128.0.Y:15001
# CREG_CHAIN_SPEC_URL=http://10.128.0.Y:18888/chain-spec.json
#   .\testnet\gcp\get-validator-fleet-internal-ip.ps1

# ── Hybrid mode (validators local, edge on GCP — legacy) ──
# See docs/HYBRID-LOCAL-VALIDATORS.md
# CREG_HYBRID_MODE=true
# CREG_WG_LOCAL_PEER=10.200.0.2
# CREG_CLOUD_IPFS_URL=https://ipfs.testnet.cregnet.dev
# CREG_CLOUD_CHAIN_SPEC_URL=https://spec.testnet.cregnet.dev/chain-spec.json
# CREG_WAITLIST_HOST_PORT=8088

# Host port for 3-node IPFS API (containers use http://ipfs:5001 internally)
CREG_3NODE_IPFS_HOST_PORT=15001
CREG_3NODE_SPEC_HOST_PORT=18888
# Host ports for node APIs/P2P (avoid clashes with creg-node, minio, faucet, etc.)
CREG_3NODE_NODE1_API_PORT=28180
CREG_3NODE_NODE1_P2P_PORT=29100
CREG_3NODE_NODE2_API_PORT=28181
CREG_3NODE_NODE2_P2P_PORT=29101
CREG_3NODE_NODE3_API_PORT=28182
CREG_3NODE_NODE3_P2P_PORT=29102
CREG_3NODE_FAUCET_PORT=8082
# Default 3017 avoids clash with docker-compose.yml web-explorer (:3007) and stale WSL port relays on Windows.
CREG_3NODE_EXPLORER_PORT=3017

# Security / bridge (optional — enables L1 anchoring when set on validator-1)
# CREG_BRIDGE_KEY=0x...
# CREG_OPERATOR_API_KEY=docker-dev-operator-key

# Windows dev soak without nsjail (NET-301 only; not SANDBOX-301):
# CREG_DEV_SANDBOX=true
#
# SANDBOX-301: use start-3node-sandbox.ps1 (secure image sets CREG_DEV_SANDBOX=false on validators).
#
# MAL-001 (public fleet): start-validator-fleet-gcp.sh builds the nsjail secure
# image and applies docker-compose.fleet-sandbox.yml by default. Keep this set
# to false on any public validator profile; verify with
# .\testnet\gcp\verify-fleet-sandbox.ps1
CREG_DEV_SANDBOX=false

# Faucet (optional — start with .\testnet\start-3node-public.ps1 -WithFaucet)
# FAUCET_PRIVATE_KEY=0x...
# FAUCET_ADDRESS=0x...
# Production edge: prefer Vault (see testnet/gcp/faucet-vault-env.example)
# CREG_SECRETS_BACKEND=vault
# FAUCET_POW_DISABLED=false
# Cloud-edge compose defaults PoW on; set FAUCET_POW_DISABLED=true only for local dev soak.

# ── Sepolia contracts (optional — compose defaults match chain-spec.sepolia.json) ──
# CREG_REGISTRY_ADDR=0x3aCfF05d00AC199412a94326eD8aA874aaA3596c
# CREG_STAKING_ADDR=0xf28C63C4Aafd27025E535Ab9ab7B4daC18C96Bc2
# CREG_GOVERNANCE_ADDR=0x9a14F359E2bdBb43F1526743C4A91955F29Ba59A
# CREG_TOKEN_ADDR=0x97c21d46B3eac604e92E907D54aA92eEc0Af550b

# ── Validator Ed25519 seeds (32-byte hex) ──
# Use init-sepolia-3node-env.ps1 for working defaults (KEY_1 = chain-spec core-1).
CREG_VALIDATOR_KEY_1=0xREPLACE_WITH_VALIDATOR_1_ED25519_SEED
CREG_VALIDATOR_KEY_2=0xREPLACE_WITH_VALIDATOR_2_ED25519_SEED

# For on-chain validator-2 registration (never commit):
# VALIDATOR_2_ETH_PRIVATE_KEY=0x...   # Sepolia wallet with >= 100 tCREG for applyToBeValidator

# ── Public internet hosting (GCP + Caddy ingress) ──
# Register testnet.YOUR_DOMAIN via Google Cloud Domains, point DNS A records at the VM,
# then patch the chain spec: .\testnet\patch-sepolia-chain-spec-services.ps1 -BaseDomain testnet.YOUR_DOMAIN
# Full runbook: testnet/gcp-public-hosting.md
#
# CREG_ACME_EMAIL=you@example.com
# CREG_PUBLIC_WAITLIST_HOST=waitlist.cregnet.dev
# Join portal hub (Phase 1+): start-cloud-edge-gcp.sh copies hub-edge.caddy.example when set
# CREG_PUBLIC_JOIN_HOST=testnet.cregnet.dev
# CREG_HUB_WEB_PORT=8094
# CREG_HUB_API_PORT=8095
# CREG_PUBLIC_BASE_DOMAIN=testnet.YOUR_DOMAIN
# CREG_PUBLIC_API_HOST=api.testnet.YOUR_DOMAIN
# CREG_PUBLIC_EXPLORER_HOST=explorer.testnet.YOUR_DOMAIN
# CREG_PUBLIC_FAUCET_HOST=faucet.testnet.YOUR_DOMAIN
# CREG_PUBLIC_SPEC_HOST=spec.testnet.YOUR_DOMAIN
# CREG_PUBLIC_IPFS_HOST=ipfs.testnet.YOUR_DOMAIN
# CREG_PUBLIC_EXPLORER_URL=https://explorer.testnet.YOUR_DOMAIN
# Public Sepolia JSON-RPC for wallets / cast (eth_*). NOT api.* /rpc (creg_* only).
# FAUCET_PUBLIC_RPC_URL=https://explorer.testnet.YOUR_DOMAIN/rpc
# CREG_SEPOLIA_PUBLIC_RPC_UPSTREAM=https://ethereum-sepolia-rpc.publicnode.com
# CREG_SEPOLIA_PUBLIC_RPC_UPSTREAM_HOST=ethereum-sepolia-rpc.publicnode.com
# Or internal Geth: CREG_SEPOLIA_PUBLIC_RPC_UPSTREAM=http://10.128.0.X:8545
# CREG_NODE_URL=https://api.testnet.YOUR_DOMAIN
